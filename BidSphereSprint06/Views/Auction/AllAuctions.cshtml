@model IEnumerable<Auction>

@{
    ViewData["Title"] = "All Products - BidSphere";
    var categoryName = ViewBag.CategoryName;
    var liveCount = ViewBag.LiveProductsCount;
    var totalBidders = ViewBag.TotalBidders;
    var totalBidValue = ViewBag.TotalBidValue;
    var endingSoon = ViewBag.EndingSoon;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"]</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body class="bg-light">
    <div class="container-fluid py-4">
        <!-- Header Section -->
        <div class="row mb-4">
            <div class="col">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <nav aria-label="breadcrumb">
                            <ol class="breadcrumb">
                                <li class="breadcrumb-item"><a href="#" class="text-decoration-none"><i class="fas fa-home"></i> Home</a></li>
                                <li class="breadcrumb-item active" aria-current="page">All Products</li>
                            </ol>
                        </nav>
                        <h1 class="h2 mb-1">All Live Products</h1>
                        <p class="text-muted mb-0">@liveCount live products available across all categories</p>
                    </div>
                    <div class="d-flex gap-2">
                        <div class="input-group" style="width: 300px;">
                            <input type="text" class="form-control" placeholder="Search products...">
                            <button class="btn btn-outline-secondary" type="button">
                                <i class="fas fa-search"></i>
                            </button>
                        </div>
                        <a href="@Url.Action("AllAuctions", "Auction", new { id = "Laptops" })" class="btn btn-outline-primary">
                            <i class="fas fa-filter me-2"></i>Filter by Category
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <!-- Stats Cards -->
        <div class="row mb-4">
            <div class="col-md-3 mb-3">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-body text-center">
                        <i class="fas fa-gavel fa-2x text-primary mb-3"></i>
                        <h3 class="card-title">@liveCount</h3>
                        <p class="card-text text-muted">Total Live Products</p>
                    </div>
                </div>
            </div>
            <div class="col-md-3 mb-3">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-body text-center">
                        <i class="fas fa-users fa-2x text-success mb-3"></i>
                        <h3 class="card-title">@totalBidders</h3>
                        <p class="card-text text-muted">Active Bidders</p>
                    </div>
                </div>
            </div>
            <div class="col-md-3 mb-3">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-body text-center">
                        <i class="fas fa-dollar-sign fa-2x text-warning mb-3"></i>
                        <h3 class="card-title">$@totalBidValue</h3>
                        <p class="card-text text-muted">Total Bid Value</p>
                    </div>
                </div>
            </div>
            <div class="col-md-3 mb-3">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-body text-center">
                        <i class="fas fa-clock fa-2x text-danger mb-3"></i>
                        <h3 class="card-title">@endingSoon</h3>
                        <p class="card-text text-muted">Ending Soon</p>
                    </div>
                </div>
            </div>
        </div>

        <!-- Category Quick Links -->
        <div class="row mb-4">
            <div class="col">
                <div class="card">
                    <div class="card-body">
                        <h6 class="card-title mb-3">Browse by Category:</h6>
                        <div class="d-flex flex-wrap gap-3">
                            <a href="@Url.Action("IndividualCategory", "Auction", new { id = "Laptops" })" class="category-card text-decoration-none">
                                <div class="card border-0 shadow-sm text-center h-100" style="width: 140px;">
                                    <div class="card-body py-4">
                                        <i class="fas fa-laptop fa-2x text-primary mb-2"></i>
                                        <h6 class="card-title mb-1">Laptops</h6>
                                        <small class="text-muted">@Model.Count(a => a.Item.Category == "Laptops") products</small>
                                    </div>
                                </div>
                            </a>
                            <a href="@Url.Action("IndividualCategory", "Auction", new { id = "Fashion Outfit" })" class="category-card text-decoration-none">
                                <div class="card border-0 shadow-sm text-center h-100" style="width: 140px;">
                                    <div class="card-body py-4">
                                        <i class="fas fa-tshirt fa-2x text-success mb-2"></i>
                                        <h6 class="card-title mb-1">Fashion</h6>
                                        <small class="text-muted">@Model.Count(a => a.Item.Category == "Fashion Outfit") products</small>
                                    </div>
                                </div>
                            </a>
                            <a href="@Url.Action("IndividualCategory", "Auction", new { id = "Home Appliances" })" class="category-card text-decoration-none">
                                <div class="card border-0 shadow-sm text-center h-100" style="width: 140px;">
                                    <div class="card-body py-4">
                                        <i class="fas fa-tv fa-2x text-info mb-2"></i>
                                        <h6 class="card-title mb-1">Appliances</h6>
                                        <small class="text-muted">@Model.Count(a => a.Item.Category == "Home Appliances") products</small>
                                    </div>
                                </div>
                            </a>
                            <a href="@Url.Action("IndividualCategory", "Auction", new { id = "Perfumes" })" class="category-card text-decoration-none">
                                <div class="card border-0 shadow-sm text-center h-100" style="width: 140px;">
                                    <div class="card-body py-4">
                                        <i class="fas fa-spray-can fa-2x text-warning mb-2"></i>
                                        <h6 class="card-title mb-1">Perfumes</h6>
                                        <small class="text-muted">@Model.Count(a => a.Item.Category == "Perfumes") products</small>
                                    </div>
                                </div>
                            </a>
                            <a href="@Url.Action("IndividualCategory", "Auction", new { id = "Luxury Watches" })" class="category-card text-decoration-none">
                                <div class="card border-0 shadow-sm text-center h-100" style="width: 140px;">
                                    <div class="card-body py-4">
                                        <i class="fas fa-clock fa-2x text-danger mb-2"></i>
                                        <h6 class="card-title mb-1">Watches</h6>
                                        <small class="text-muted">@Model.Count(a => a.Item.Category == "Luxury Watches") products</small>
                                    </div>
                                </div>
                            </a>
                            <a href="@Url.Action("IndividualCategory", "Auction", new { id = "Automobile" })" class="category-card text-decoration-none">
                                <div class="card border-0 shadow-sm text-center h-100" style="width: 140px;">
                                    <div class="card-body py-4">
                                        <i class="fas fa-car fa-2x text-secondary mb-2"></i>
                                        <h6 class="card-title mb-1">Automobile</h6>
                                        <small class="text-muted">@Model.Count(a => a.Item.Category == "Automobile") products</small>
                                    </div>
                                </div>
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Products Grid -->
        <div class="row">
            @if (Model.Any())
            {
                foreach (var auction in Model)
                {
                    <div class="col-xl-4 col-lg-6 col-md-6 mb-4">
                        <div class="card h-100 shadow-sm border-0">
                            <div class="card-header bg-transparent border-bottom-0 pt-3">
                                <div class="d-flex justify-content-between align-items-center">
                                    <span class="badge bg-success">Live</span>
                                    <div>
                                        <span class="badge bg-secondary">@auction.Item.Category</span>
                                        <small class="text-muted ms-2">#@auction.Item.Id</small>
                                    </div>
                                </div>
                            </div>

                            <div class="card-body">
                                <!-- Product Image Placeholder with Category-based Icons -->
                                <div class="text-white rounded-3 text-center py-4 mb-3
                                    @(auction.Item.Category == "Laptops" ? "bg-primary" :  auction.Item.Category == "Fashion Outfit" ? "bg-success" :
                                     auction.Item.Category == "Home Appliances" ? "bg-info" :
                                     auction.Item.Category == "Perfumes" ? "bg-warning" :
                                     auction.Item.Category == "Luxury Watches" ? "bg-danger" : "bg-secondary")">
                                    <i class="@(auction.Item.Category == "Laptops" ? "fas fa-laptop" :
                                    auction.Item.Category == "Fashion Outfit" ? "fas fa-tshirt" :
                                    auction.Item.Category == "Home Appliances" ? "fas fa-tv" :
                                    auction.Item.Category == "Perfumes" ? "fas fa-spray-can" :
                                    auction.Item.Category == "Luxury Watches" ? "fas fa-clock" : "fas fa-car") fa-3x"></i>
                            </div>

                                <h5 class="card-title">@auction.Item.Name</h5>
                                <p class="card-text text-muted small mb-3">
                                    <i class="fas fa-tag me-1"></i>Category: @auction.Item.Category
                                </p>

                                <!-- Price Information -->
                                <div class="row g-2 mb-3">
                                    <div class="col-6">
                                        <div class="border rounded p-2 text-center">
                                            <small class="text-muted d-block">Starting Price</small>
                                            <strong class="text-dark">$@auction.StartingPrice</strong>
                                        </div>
                                    </div>
                                    <div class="col-6">
                                        <div class="border rounded p-2 text-center bg-light">
                                            <small class="text-muted d-block">Current Bid</small>
                                            <strong class="text-primary fs-5">$@auction.CurrentPrice</strong>
                                        </div>
                                    </div>
                                </div>

                                <!-- Countdown Timer -->
                                <div class="border rounded p-3 bg-light mb-3">
                                    <small class="text-muted d-block mb-1">
                                        <i class="fas fa-clock me-1"></i>Ends in:
                                    </small>
                                    <div class="timer text-danger fw-bold fs-6" data-endtime="@auction.EndTime.ToString("yyyy-MM-ddTHH:mm:ss")">
                                        Loading...
                                    </div>
                                </div>

                                <!-- Bidder Information -->
                                <div class="d-flex justify-content-between align-items-center text-muted small mb-3">
                                    <span>
                                        <i class="fas fa-gavel me-1"></i>@auction.BidCount bids
                                    </span>
                                </div>
                            </div>

                            <div class="card-footer bg-transparent border-top-0 pb-3">
                                <div class="d-grid gap-2">
                                    <button class="btn btn-primary btn-lg place-bid-btn"
                                            data-product-id="@auction.ProductId"
                                            data-current-price="@auction.CurrentPrice">
                                        <i class="fas fa-gavel me-2"></i>Place Bid
                                    </button>
                                    <div class="d-flex gap-2">
                                        <button class="btn btn-outline-secondary view-details-btn flex-fill"
                                                data-product-id="@auction.ProductId">
                                            <i class="fas fa-info-circle me-2"></i>Details
                                        </button>
                                        <a href="@Url.Action("Category", "Product", new { id = auction.Item.Category })" class="btn btn-outline-info">
                                            <i class="fas fa-filter me-2"></i>Similar
                                        </a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="col-12">
                    <div class="card border-0 shadow-sm">
                        <div class="card-body text-center py-5">
                            <i class="fas fa-boxes fa-4x text-muted mb-4"></i>
                            <h3 class="text-muted mb-3">No Live Products</h3>
                            <p class="text-muted mb-4">There are no active products to bid on available at the moment.</p>
                        </div>
                    </div>
                </div>
            }
        </div>

        <!-- Pagination -->
        @if (Model.Any())
        {
            <div class="row mt-4">
                <div class="col">
                    <nav aria-label="Product pagination">
                        <ul class="pagination justify-content-center">
                            <li class="page-item disabled">
                                <a class="page-link" href="#" tabindex="-1">
                                    <i class="fas fa-chevron-left"></i>
                                </a>
                            </li>
                            <li class="page-item active"><a class="page-link" href="#">1</a></li>
                            <li class="page-item"><a class="page-link" href="#">2</a></li>
                            <li class="page-item"><a class="page-link" href="#">3</a></li>
                            <li class="page-item">
                                <a class="page-link" href="#">
                                    <i class="fas fa-chevron-right"></i>
                                </a>
                            </li>
                        </ul>
                    </nav>
                </div>
            </div>
        }
    </div>

    <!-- Place Bid Modal : shown when user clicks on place a bid so a dialog box will apper -->  
    <div class="modal fade" id="placeBidModal" tabindex="-1" aria-labelledby="placeBidModalLabel" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="placeBidModalLabel">Place Your Bid</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <p>Current Highest Bid: $<span id="currentBidAmount">0</span></p>
                    <input type="number" id="bidAmount" class="form-control" placeholder="Enter your bid" min="0">
                    <div id="bidError" class="text-danger mt-2" style="display:none;"></div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="button" class="btn btn-primary" id="submitBidBtn">Place Bid</button>
                </div>
            </div>
        </div>
    </div>

    <script src="https://code.jquery.com/jquery-3.7.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        // Countdown Timer Functionality
        function updateTimers() {
            $('.timer').each(function() {
                const endTime = new Date($(this).data('endtime'));
                const now = new Date();
                const timeDiff = endTime - now;

                if (timeDiff <= 0) {
                    $(this).text('Auction Ended');
                    $(this).closest('.card').find('.place-bid-btn').prop('disabled', true).removeClass('btn-primary').addClass('btn-secondary');
                    $(this).closest('.card').find('.badge').removeClass('bg-success').addClass('bg-danger').text('Ended');
                } else {
                    const days = Math.floor(timeDiff / (1000 * 60 * 60 * 24));
                    const hours = Math.floor((timeDiff % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
                    const minutes = Math.floor((timeDiff % (1000 * 60 * 60)) / (1000 * 60));
                    const seconds = Math.floor((timeDiff % (1000 * 60)) / 1000);

                    // if days >0 then only shown 
                    let display = '';
                    if (days > 0) display += `${days}d `;
                    display += `${hours}h ${minutes}m ${seconds}s`;
                    $(this).text(display);
                }
            });
        }

        // Initialize timers and event handlers
        $(document).ready(function() {
            updateTimers();
            setInterval(updateTimers, 1000);

            let selectedAuctionId = null;
            let currentPrice = 0;

            // When Place Bid button is clicked
            $('.place-bid-btn').click(function() {
                selectedAuctionId = $(this).data('product-id');
                currentPrice = $(this).data('current-price');

                // Populate modal fields
                $('#currentBidAmount').text(currentPrice);
                $('#bidAmount').val(currentPrice + 1); // default next valid bid
                $('#bidAmount').attr('min', currentPrice + 1);
                $('#bidError').hide();

                // Show modal
                $('#placeBidModal').modal('show');
            });

            // When user clicks Submit Bid
            $('#submitBidBtn').click(function() {
                const bidValue = parseFloat($('#bidAmount').val());

                if (bidValue <= currentPrice) {
                    $('#bidError').text('Your bid must be higher than current bid!').show();
                    return;
                }

                // AJAX call to send bid to server
                $.ajax({
                    url: '/Auction/PlaceBid', // you will create this action
                    type: 'POST',
                    data: {
                        auctionId: selectedAuctionId,
                        bidAmount: bidValue
                    },
                    success: function(response) {
                        alert('Bid placed successfully!');
                        $('#placeBidModal').modal('hide');

                        // Update current price on card
                        $(`[data-product-id=${selectedAuctionId}]`).data('current-price', bidValue);
                        $(`[data-product-id=${selectedAuctionId}]`).closest('.card').find('.text-primary.fs-5').text(`$${bidValue}`);
                    },
                    error: function(err) {
                        $('#bidError').text('Error placing bid. Try again.').show();
                    }
                });
            });

            $('.view-details-btn').click(function() {
                const productId = $(this).data('product-id');
                alert(`Viewing details for Product #${productId}`);
            });

            // Category card hover effects
            $('.category-card .card').hover(
                function() {
                    $(this).addClass('shadow-lg').css('transform', 'translateY(-5px)');
                },
                function() {
                    $(this).removeClass('shadow-lg').css('transform', 'translateY(0)');
                }
            );
        });
    </script>
</body>
</html>
