@model IEnumerable<Auction>

@{
    ViewData["Title"] = $"{ViewBag.CategoryName} - BidSphere";
    var categoryName = ViewBag.CategoryName;
    var liveCount = ViewBag.LiveProductsCount;
    var totalBidders = ViewBag.TotalBidders;
    var totalBidValue = ViewBag.TotalBidValue;
    var endingSoon = ViewBag.EndingSoon;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"]</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body class="bg-light">
    <div class="container-fluid py-4">
        <!-- Header Section -->
        <div class="row mb-4">
            <div class="col">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <nav aria-label="breadcrumb">
                            <ol class="breadcrumb">
                                <li class="breadcrumb-item"><a href="#" class="text-decoration-none"><i class="fas fa-home"></i> Home</a></li>
                                <li class="breadcrumb-item"><a href="#" class="text-decoration-none">Products</a></li>
                                <li class="breadcrumb-item active" aria-current="page">@categoryName</li>
                            </ol>
                        </nav>
                        <h1 class="h2 mb-1">@categoryName Auctions</h1>
                        <p class="text-muted mb-0">@liveCount live auctions available for bidding</p>
                    </div>
                    <a href="@Url.Action("AllAuctions", "Auction")" class="btn btn-outline-primary">
                        <i class="fas fa-arrow-left me-2"></i>View All Categories
                    </a>
                </div>
            </div>
        </div>

        <!-- Stats Cards -->
        <div class="row mb-4">
            <div class="col-md-3 mb-3">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-body text-center">
                        <i class="fas fa-gavel fa-2x text-primary mb-3"></i>
                        <h3 class="card-title">@liveCount</h3>
                        <p class="card-text text-muted">Live Products</p>
                    </div>
                </div>
            </div>
            <div class="col-md-3 mb-3">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-body text-center">
                        <i class="fas fa-users fa-2x text-success mb-3"></i>
                        <h3 class="card-title">@totalBidders</h3>
                        <p class="card-text text-muted">Active Bidders</p>
                    </div>
                </div>
            </div>
            <div class="col-md-3 mb-3">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-body text-center">
                        <i class="fas fa-dollar-sign fa-2x text-warning mb-3"></i>
                        <h3 class="card-title">$@totalBidValue</h3>
                        <p class="card-text text-muted">Total Bid Value</p>
                    </div>
                </div>
            </div>
            <div class="col-md-3 mb-3">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-body text-center">
                        <i class="fas fa-clock fa-2x text-danger mb-3"></i>
                        <h3 class="card-title">@endingSoon</h3>
                        <p class="card-text text-muted">Ending Soon</p>
                    </div>
                </div>
            </div>
        </div>

        <!-- Category Navigation -->
        <div class="row mb-4">
            <div class="col">
                <div class="card">
                    <div class="card-body">
                        <h6 class="card-title mb-3">Browse Categories:</h6>
                        <div class="d-flex flex-wrap gap-2">
                            <a href="@Url.Action("IndividualCategory", "Auction", new { id = "Laptops" })" class="btn @(categoryName == "Laptops" ? "btn-primary" : "btn-outline-primary") btn-sm">Laptops</a>
                            <a href="@Url.Action("IndividualCategory", "Auction", new { id = "Fashion Outfit" })" class="btn @(categoryName == "Fashion Outfit" ? "btn-primary" : "btn-outline-primary") btn-sm">Fashion</a>
                            <a href="@Url.Action("IndividualCategory", "Auction", new { id = "Home Appliances" })" class="btn @(categoryName == "Home Appliances" ? "btn-primary" : "btn-outline-primary") btn-sm">Appliances</a>
                            <a href="@Url.Action("IndividualCategory", "Auction", new { id = "Perfumes" })" class="btn @(categoryName == "Perfumes" ? "btn-primary" : "btn-outline-primary") btn-sm">Perfumes</a>
                            <a href="@Url.Action("IndividualCategory", "Auction", new { id = "Luxury Watches" })" class="btn @(categoryName == "Luxury Watches" ? "btn-primary" : "btn-outline-primary") btn-sm">Watches</a>
                            <a href="@Url.Action("IndividualCategory", "Auction", new { id = "Automobile" })" class="btn @(categoryName == "Automobile" ? "btn-primary" : "btn-outline-primary") btn-sm">Automobile</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Products Grid -->
        <div class="row">
            @if (Model.Any())
            {
                foreach (var auction in Model)
                {
                    <div class="col-xl-4 col-lg-6 col-md-6 mb-4">
                        <div class="card h-100 shadow-sm border-0">
                            <div class="card-header bg-transparent border-bottom-0 pt-3">
                                <div class="d-flex justify-content-between align-items-center">
                                    <span class="badge bg-success">Live</span>
                                    <small class="text-muted">ID: #@auction.Id</small>
                                </div>
                            </div>

                            <div class="card-body">
                                <!-- Product Image Placeholder -->
                                <div class="bg-primary text-white rounded-3 text-center py-4 mb-3">
                                    <i class="fas fa-box fa-3x"></i>
                                </div>

                                <h5 class="card-title">@auction.Item.Name</h5>
                                <p class="card-text text-muted small mb-3">
                                    <i class="fas fa-tag me-1"></i>Category: @auction.Item.Category
                                </p>

                                <!-- Price Information -->
                                <div class="row g-2 mb-3">
                                    <div class="col-6">
                                        <div class="border rounded p-2 text-center">
                                            <small class="text-muted d-block">Starting Price</small>
                                            <strong class="text-dark">$@auction.StartingPrice</strong>
                                        </div>
                                    </div>
                                    <div class="col-6">
                                        <div class="border rounded p-2 text-center bg-light">
                                            <small class="text-muted d-block">Current Bid</small>
                                            <strong class="text-primary fs-5">$@auction.CurrentPrice</strong>
                                        </div>
                                    </div>
                                </div>

                                <!-- Countdown Timer -->
                                <div class="border rounded p-3 bg-light mb-3">
                                    <small class="text-muted d-block mb-1">
                                        <i class="fas fa-clock me-1"></i>Ends in:
                                    </small>
                                    <div class="timer text-danger fw-bold fs-6" data-endtime="@auction.EndTime.ToString("yyyy-MM-ddTHH:mm:ss")">
                                        Loading...
                                    </div>
                                </div>

                                <!-- Bidder Information -->
                                <div class="d-flex justify-content-between align-items-center text-muted small mb-3">
                                    
                                    <span>
                                        <i class="fas fa-gavel me-1"></i>@auction.BidCount bids
                                    </span>
                                </div>
                            </div>

                            <div class="card-footer bg-transparent border-top-0 pb-3">
                                <div class="d-grid gap-2">
                                    <button class="btn btn-primary btn-lg place-bid-btn"
                                            data-product-id="@auction.ProductId"
                                            data-current-price="@auction.CurrentPrice">
                                        <i class="fas fa-gavel me-2"></i>Place Bid
                                    </button>
                                    <button class="btn btn-outline-secondary view-details-btn"
                                            data-product-id="@auction.ProductId">
                                        <i class="fas fa-info-circle me-2"></i>View Details
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="col-12">
                    <div class="card border-0 shadow-sm">
                        <div class="card-body text-center py-5">
                            <i class="fas fa-box fa-4x text-muted mb-4"></i>
                            <h3 class="text-muted mb-3">No Live Auctions</h3>
                            <p class="text-muted mb-4">There are no active auctions in the @categoryName category at the moment.</p>
                            <a href="@Url.Action("AllAuctions", "Auction")" class="btn btn-primary">
                                <i class="fas fa-list me-2"></i>Browse All Categories
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>

    <script src="https://code.jquery.com/jquery-3.7.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        // Countdown Timer Functionality
        function updateTimers() {
            $('.timer').each(function() {
                const endTime = new Date($(this).data('endtime'));
                const now = new Date();
                const timeDiff = endTime - now;

                if (timeDiff <= 0) {
                    $(this).text('Auction Ended');
                    $(this).closest('.card').find('.place-bid-btn').prop('disabled', true).removeClass('btn-primary').addClass('btn-secondary');
                    $(this).closest('.card').find('.badge').removeClass('bg-success').addClass('bg-danger').text('Ended');
                } else {
                    const hours = Math.floor((timeDiff % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
                    const minutes = Math.floor((timeDiff % (1000 * 60 * 60)) / (1000 * 60));
                    const seconds = Math.floor((timeDiff % (1000 * 60)) / 1000);

                    $(this).text(`${hours}h ${minutes}m ${seconds}s`);
                }
            });
        }

        // Initialize timers and event handlers
        $(document).ready(function() {
            updateTimers();
            setInterval(updateTimers, 1000);

            $('.place-bid-btn').click(function() {
                const productId = $(this).data('product-id');
                const currentPrice = $(this).data('current-price');
                alert(`Placing bid on Product #${productId}\nCurrent Price: $${currentPrice}`);
            });

            $('.view-details-btn').click(function() {
                const productId = $(this).data('product-id');
                alert(`Viewing details for Product #${productId}`);
            });
        });
    </script>
</body>
</html>