@model IEnumerable<Auction>

@{
    ViewData["Title"] = $"{ViewBag.CategoryName} - BidSphere";
    var categoryName = ViewBag.CategoryName;
    var liveCount = ViewBag.ProductCount;
    var totalBidders = ViewBag.TotalBidders;
    var totalBidValue = ViewBag.TotalBidValue;
    var endingSoon = ViewBag.EndingSoon;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"]</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body class="bg-light">
    <div class="container-fluid py-4">
        <!-- Header Section -->
        <div class="row mb-4">
            <div class="col">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <nav aria-label="breadcrumb">
                            <ol class="breadcrumb">
                                <li class="breadcrumb-item"><a href="#" class="text-decoration-none"><i class="fas fa-home"></i> Home</a></li>
                                <li class="breadcrumb-item"><a href="#" class="text-decoration-none">Products</a></li>
                                <li class="breadcrumb-item active" aria-current="page">@categoryName</li>
                            </ol>
                        </nav>
                        <h1 class="h2 mb-1">@categoryName Auctions</h1>
                        <p class="text-muted mb-0">@liveCount live auctions available for bidding</p>
                    </div>
                    <a href="@Url.Action("AllAuctions", "Auction")" class="btn btn-outline-primary">
                        <i class="fas fa-arrow-left me-2"></i>View All Categories
                    </a>
                </div>
            </div>
        </div>

        <!-- Stats Cards -->
        <div class="row mb-4">
            <div class="col-md-3 mb-3">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-body text-center">
                        <i class="fas fa-gavel fa-2x text-primary mb-3"></i>
                        <h3 class="card-title">@liveCount</h3>
                        <p class="card-text text-muted">Live Products</p>
                    </div>
                </div>
            </div>
            <div class="col-md-3 mb-3">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-body text-center">
                        <i class="fas fa-users fa-2x text-success mb-3"></i>
                        <h3 class="card-title">@totalBidders</h3>
                        <p class="card-text text-muted">Active Bidders</p>
                    </div>
                </div>
            </div>
            <div class="col-md-3 mb-3">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-body text-center">
                        <i class="fas fa-dollar-sign fa-2x text-warning mb-3"></i>
                        <h3 class="card-title">$@totalBidValue</h3>
                        <p class="card-text text-muted">Total Bid Value</p>
                    </div>
                </div>
            </div>
            <div class="col-md-3 mb-3">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-body text-center">
                        <i class="fas fa-clock fa-2x text-danger mb-3"></i>
                        <h3 class="card-title">@endingSoon</h3>
                        <p class="card-text text-muted">Ending Soon</p>
                    </div>
                </div>
            </div>
        </div>

        <!-- Category Navigation -->
        <div class="row mb-4">
            <div class="col">
                <div class="card">
                    <div class="card-body">
                        <h6 class="card-title mb-3">Browse Categories:</h6>
                        <div class="d-flex flex-wrap gap-2">
                            <a href="@Url.Action("IndividualCategory", "Auction", new { id = "Laptops" })" class="btn @(categoryName == "Laptops" ? "btn-primary" : "btn-outline-primary") btn-sm">Laptops</a>
                            <a href="@Url.Action("IndividualCategory", "Auction", new { id = "Fashion Outfit" })" class="btn @(categoryName == "Fashion Outfit" ? "btn-primary" : "btn-outline-primary") btn-sm">Fashion</a>
                            <a href="@Url.Action("IndividualCategory", "Auction", new { id = "Home Appliances" })" class="btn @(categoryName == "Home Appliances" ? "btn-primary" : "btn-outline-primary") btn-sm">Appliances</a>
                            <a href="@Url.Action("IndividualCategory", "Auction", new { id = "Perfumes" })" class="btn @(categoryName == "Perfumes" ? "btn-primary" : "btn-outline-primary") btn-sm">Perfumes</a>
                            <a href="@Url.Action("IndividualCategory", "Auction", new { id = "Luxury Watches" })" class="btn @(categoryName == "Luxury Watches" ? "btn-primary" : "btn-outline-primary") btn-sm">Watches</a>
                            <a href="@Url.Action("IndividualCategory", "Auction", new { id = "Automobile" })" class="btn @(categoryName == "Automobile" ? "btn-primary" : "btn-outline-primary") btn-sm">Automobile</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Products Grid - USING PARTIAL VIEW -->
        <div class="row">
            @if (Model.Any())
            {
                foreach (var auction in Model)
                {
                    <!-- Call the partial view for each auction -->
                    <partial name="_AuctionCard" model="auction" />
                }
            }
            else
            {
                <div class="col-12">
                    <div class="card border-0 shadow-sm">
                        <div class="card-body text-center py-5">
                            <i class="fas fa-boxes fa-4x text-muted mb-4"></i>
                            <h3 class="text-muted mb-3">No Live Products</h3>
                            <p class="text-muted mb-4">There are no active products to bid on available at the moment.</p>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>

    <!-- Pagination -->
    @if (Model.Any())
    {
        <div class="row mt-4">
            <div class="col">
                <nav aria-label="Product pagination">
                    <ul class="pagination justify-content-center">
                        <li class="page-item disabled">
                            <a class="page-link" href="#" tabindex="-1">
                                <i class="fas fa-chevron-left"></i>
                            </a>
                        </li>
                        <li class="page-item active"><a class="page-link" href="#">1</a></li>
                        <li class="page-item"><a class="page-link" href="#">2</a></li>
                        <li class="page-item"><a class="page-link" href="#">3</a></li>
                        <li class="page-item">
                            <a class="page-link" href="#">
                                <i class="fas fa-chevron-right"></i>
                            </a>
                        </li>
                    </ul>
                </nav>
            </div>
        </div>
    }
    </div>

    <!-- Place Bid Modal : shown when user clicks on place a bid so a dialog box will apper -->
    <div class="modal fade" id="placeBidModal" tabindex="-1" aria-labelledby="placeBidModalLabel" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="placeBidModalLabel">Place Your Bid</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <p>Current Highest Bid: $<span id="currentBidAmount">0</span></p>
                    <input type="number" id="bidAmount" class="form-control" step="1" onkeydown="return event.key !== '.'" placeholder="Enter your bid" min="0">
                    <div id="bidError" class="text-danger mt-2" style="display:none;"></div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="button" class="btn btn-primary" id="submitBidBtn">Place Bid</button>
                </div>
            </div>
        </div>
    </div>

    <script src="https://code.jquery.com/jquery-3.7.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        // Countdown Timer Functionality
        function updateTimers() {
            $('.timer').each(function() {
                const endTime = new Date($(this).data('endtime'));
                const now = new Date();
                const timeDiff = endTime - now;

                if (timeDiff <= 0) {
                    $(this).text('Auction Ended');
                    $(this).closest('.card').find('.place-bid-btn').prop('disabled', true).removeClass('btn-primary').addClass('btn-secondary');
                    $(this).closest('.card').find('.badge').removeClass('bg-success').addClass('bg-danger').text('Ended');
                } else {
                    const days = Math.floor(timeDiff / (1000 * 60 * 60 * 24));
                    const hours = Math.floor((timeDiff % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
                    const minutes = Math.floor((timeDiff % (1000 * 60 * 60)) / (1000 * 60));
                    const seconds = Math.floor((timeDiff % (1000 * 60)) / 1000);

                    // if days >0 then only shown
                    let display = '';
                    if (days > 0) display += `${days}d `;
                    display += `${hours}h ${minutes}m ${seconds}s`;
                    $(this).text(display);
                }
            });
        }

        // Initialize timers and event handlers
        $(document).ready(function() {
            updateTimers();
            setInterval(updateTimers, 1000);

            let selectedAuctionId = null;
            let currentPrice = 0;

            // When Place Bid button is clicked
            $('.place-bid-btn').click(function() {
                selectedAuctionId = $(this).data('product-id');
                currentPrice = $(this).data('current-price');
                var productName = $(this).data('product-name'); // Get product name

                // Populate modal fields
                $('#currentBidAmount').text(currentPrice);
                $('#bidAmount').val(currentPrice + 1); // default next valid bid
                $('#bidAmount').attr('min', currentPrice + 1);
                $('#bidError').hide();

                // Show modal
                $('#placeBidModal').modal('show');
            });

            // When user clicks Submit Bid
            $('#submitBidBtn').click(function() {
                const bidValue = parseInt($('#bidAmount').val(),10);

                if (bidValue <= currentPrice) {
                    $('#bidError').text('Your bid must be higher than current bid!').show();
                    return;
                }

                // AJAX call to send bid to server
                $.ajax({
                    url: '/Bid/PlaceBid', // you will create this action
                    type: 'POST',
                    data: {
                        auctionId: selectedAuctionId,
                        bidAmount: bidValue
                    },
                    success: function(response) {
                        //alert('Bid placed successfully!');
                        alert(response);
                        $('#placeBidModal').modal('hide');

                        // Update current price on card
                        $(`[data-product-id=${selectedAuctionId}]`).data('current-price', bidValue);
                        $(`[data-product-id=${selectedAuctionId}]`).closest('.card').find('.text-primary.fs-5').text(`$${bidValue}`);
                    },
                    error: function (xhr) {
                        alert(xhr.responseText);}
                    });
            });

            $('.view-details-btn').click(function() {
                const productId = $(this).data('product-id');
                alert(`Viewing details for Product #${productId}`);
            });

            // Category card hover effects
            $('.category-card .card').hover(
                function() {
                    $(this).addClass('shadow-lg').css('transform', 'translateY(-5px)');
                },
                function() {
                    $(this).removeClass('shadow-lg').css('transform', 'translateY(0)');
                }
            );
        });
    </script>
</body>
</html>