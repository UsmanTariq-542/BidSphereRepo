<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>BidSphere-Bid Smart. Win Big.</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    @RenderSection("Styles", required: false)
    
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-light bg-white shadow-sm sticky-top">
        <div class="container-fluid">
            <a class="navbar-brand fw-bold text-primary" asp-area="" asp-controller="Home" asp-action="Index">
                <i class="bi bi-currency-exchange"></i> BidSphere
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav me-auto">
                    <li class="nav-item">
                        <a class="nav-link active" href="/Home/Index">Home</a>
                    </li>
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" href="#" id="categoriesDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                            Live Auctions
                        </a>
                        <ul class="dropdown-menu" aria-labelledby="categoriesDropdown">
                            <li><a class="dropdown-item" href="/Auction/AllAuctions">AllCategory</a></li>
                            <li><a class="dropdown-item" href="/Auction/IndividualCategory/Perfumes">Perfumes</a></li>
                            <li><a class="dropdown-item" href="/Auction/IndividualCategory/Home Appliances">Home Appliances</a></li>
                            <li><a class="dropdown-item" href="/Auction/IndividualCategory/Automobiles">Automobile</a></li>
                            <li><a class="dropdown-item" href="/Auction/IndividualCategory/Fashion Outfit">Fashion Outfit</a></li>
                            <li><a class="dropdown-item" href="/Auction/IndividualCategory/Laptops">Laptops</a></li>
                            <li><a class="dropdown-item" href="/Auction/IndividualCategory/Luxury Watches">Luxury Watches</a></li>
                        </ul>
                    </li>
                    
                    <li class="nav-item">
                        <a class="nav-link active" href="/User/MyBids">My Bids</a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" href="/Home/Contact">Contact Us</a>
                    </li>
                </ul>

                

                @if (User.Identity.IsAuthenticated)
                {
                    <a href="/Identity/Account/Manage" class="btn btn-outline-dark me-2">
                        <i class="fas fa-user"></i>
                    </a>
                }
                
                @if (User.Identity.IsAuthenticated){
                    <span class="navbar-text me-2">
                        Hello, @User.Identity.Name
                    </span>
                    <form method="post" action="/Identity/Account/Logout" class="d-inline">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-dark">
                            <i class="fas fa-sign-out-alt"></i> Logout
                        </button>
                    </form>
                }

                else{
                    <!-- User is NOT logged in -->
                    <a href="/Identity/Account/Register" class="btn btn-primary">
                        <i class="fas fa-sign-in-alt"></i> Register
                    </a>
                    <a href="/Identity/Account/Login" class="btn btn-dark ms-2">
                        <i class="fas fa-sign-in-alt"></i> Login
                    </a>
                }
            </div>
        </div>
    </nav>


    <div>
        <main role="main">
            @RenderBody()
        </main>
    </div>

    
        <!-- Footer older -->
    <footer class="text-white mt-2" style="background-color: black;">
        <div class="container p-4">

            <!-- Footer Grid -->
            <div class="row gx-4 gy-4">

                <!-- Brand / About -->
                <div class="col-12 col-md-3">
                    <h6 class="text-uppercase mb-3 font-weight-bold">BidSphere</h6>
                    <p>
                        BidSphere is your trusted online auction platform — explore top-quality products, bid smartly, and win the best deals across categories.
                    </p>
                </div>

                <!-- Auction Categories -->
                <div class="col-6 col-md-2">
                    <h6 class="text-uppercase mb-3 font-weight-bold">Categories</h6>
                    <p><a href="/Auction/IndividualCategory/Automobiles" class="text-white text-decoration-none">Automobiles</a></p>
                    <p><a href="/Auction/IndividualCategory/Fashion Outfit" class="text-white text-decoration-none">Fashion</a></p>
                    <p><a href="/Auction/IndividualCategory/Home Appliances" class="text-white text-decoration-none">Home Appliances</a></p>
                    <p><a href="/Auction/IndividualCategory/Laptops" class="text-white text-decoration-none">Laptops</a></p>
                    <p><a href="/Auction/IndividualCategory/Perfumes" class="text-white text-decoration-none">Perfumes</a></p>
                    <p><a href="/Auction/IndividualCategory/Luxury Watches" class="text-white text-decoration-none">Watches</a></p>
                </div>

                <!-- Useful Links -->
                <div class="col-6 col-md-2">
                    <h6 class="text-uppercase mb-3 font-weight-bold">Useful Links</h6>
                    <p><a href="/Home/Index" class="text-white text-decoration-none">Home</a></p>
                    <p><a href="#" class="text-white text-decoration-none">Live Auctions</a></p>
                    <p><a href="/Home/Contact" class="text-white text-decoration-none">Contact Us</a></p>
                </div>

                <!-- Contact -->
                <div class="col-12 col-md-5">
                    <h6 class="text-uppercase mb-3 font-weight-bold">Contact</h6>
                    <p><i class="fas fa-home"></i>Lahore, Pakistan</p>
                    <p><i class="fas fa-envelope"></i>info@bidsphere.com</p>
                    <p><i class="fas fa-phone"></i>+92 300 1234567</p>
                </div>

            </div> <!-- End row -->

            <hr class="my-3">

            <!-- Copyright -->
            <div class="row">
                <div class="col-md-7 text-center text-md-start">
                    <p class="mb-0">© 2025 BidSphere. All rights reserved.</p>
                </div>
                <div class="col-md-5 text-center text-md-end">
                    <!-- Optional: additional links or icons here -->
                </div>
            </div>

        </div> <!-- End container -->
    </footer>



    <script src="/lib/jquery/dist/jquery.min.js"></script>
    <script src="/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>


    


