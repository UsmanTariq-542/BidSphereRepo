
@model IEnumerable<Bid>

@{
    ViewData["Title"] = "My Bids";
}

<div class="container mt-4">
    <h2 class="mb-4">My Bids</h2>

    <!-- Statistics Cards -->
    <div class="row mb-4">
        <div class="col-md-3">
            <div class="card border-primary">
                <div class="card-body text-center">
                    <h3 class="text-primary">@ViewBag.TotalBids</h3>
                    <p class="card-text text-muted">Total Bids</p>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-success">
                <div class="card-body text-center">
                    <h3 class="text-success">@ViewBag.ActiveBids</h3>
                    <p class="card-text text-muted">Active Bids</p>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-warning">
                <div class="card-body text-center">
                    <h3 class="text-warning">@ViewBag.WinningBids</h3>
                    <p class="card-text text-muted">Winning</p>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-info">
                <div class="card-body text-center">
                    <h3 class="text-info">@ViewBag.WonBids</h3>
                    <p class="card-text text-muted">Won</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Bids List -->
    <div class="card shadow">
        <div class="card-header bg-white">
            <h5 class="mb-0">Your Bidding History</h5>
        </div>

        <div class="card-body p-0">
            @if (Model != null && Model.Any())
            {
                <div class="list-group list-group-flush">
                    @foreach (var bid in Model)
                    {
                        var auction = bid.AuctionInfo;

                        if (auction == null)
                        {
                            <div class="list-group-item">
                                <div class="row align-items-center">
                                    <div class="col-auto">
                                        <div class="bg-secondary text-white rounded-circle p-3">
                                            <i class="fas fa-question fa-lg"></i>
                                        </div>
                                    </div>
                                    <div class="col">
                                        <h6 class="mb-1">Bid on Auction #@bid.AuctionId</h6>
                                        <p class="text-muted mb-1">Your Bid: <strong>$@bid.Amount.ToString("N2")</strong></p>
                                        <p class="text-muted mb-0">Placed: @bid.BidTime.ToString("MMM dd, yyyy h:mm tt")</p>
                                    </div>
                                </div>
                            </div>
                            continue;
                        }

                        // Auction exists
                        var isActive = auction.EndTime > DateTime.Now;
                        var status = auction.Status ?? "Unknown";
                        var statusClass = status.ToLower().Replace(" ", "");
                        var product = auction.Item;
                        var productName = product?.Name ?? $"Product #{auction.ProductId}";
                        var productCategory = product?.Category ?? "General";
                        var currentPrice = auction.CurrentPrice;
                        var endTime = auction.EndTime;
                        var timeLeft = endTime - DateTime.Now;

                        <div class="list-group-item border-bottom">
                            <div class="row align-items-center">
                                <!-- Product Image/Icon -->
                                <div class="col-auto">
                                    <div class="bg-primary text-white rounded-circle p-3">
                                        <i class="fas fa-gavel fa-lg"></i>
                                    </div>
                                </div>

                                <!-- Product Details -->
                                <div class="col">
                                    <div class="d-flex justify-content-between align-items-start">
                                        <div>
                                            <h6 class="mb-1">@productName</h6>
                                            <p class="text-muted mb-1">
                                                <i class="fas fa-tag me-1"></i>@productCategory
                                                <span class="mx-2">•</span>
                                                <i class="fas fa-clock me-1"></i>
                                                @if (isActive)
                                                {
                                                    <span class="text-success">
                                                        Ends @endTime.ToString("MMM dd, h:mm tt")
                                                        (@timeLeft.Days days @timeLeft.Hours hours left)
                                                    </span>
                                                }
                                                else
                                                {
                                                    <span class="text-muted">Ended @endTime.ToString("MMM dd, h:mm tt")</span>
                                                }
                                            </p>
                                        </div>
                                        <div>
                                            @if (status == "Winning")
                                            {
                                                <span class="badge bg-success">Winning</span>
                                            }
                                            else if (status == "Won")
                                            {
                                                <span class="badge bg-primary">Won</span>
                                            }
                                            else if (status == "Active")
                                            {
                                                <span class="badge bg-info">Active</span>
                                            }
                                            else if (status == "Lost")
                                            {
                                                <span class="badge bg-danger">Lost</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-secondary">@status</span>
                                            }
                                        </div>
                                    </div>

                                    <!-- Bid Details -->
                                    <div class="row mt-3">
                                        <div class="col-md-4">
                                            <div class="d-flex align-items-center">
                                                <div class="flex-grow-1">
                                                    <small class="text-muted">Your Bid</small>
                                                    <h5 class="mb-0 text-primary">$@bid.Amount.ToString("N2")</h5>
                                                </div>
                                            </div>
                                        </div>
                                        <div class="col-md-4">
                                            <div class="d-flex align-items-center">
                                                <div class="flex-grow-1">
                                                    <small class="text-muted">Current Highest</small>
                                                    <h5 class="mb-0">$@currentPrice.ToString("N2")</h5>
                                                </div>
                                            </div>
                                        </div>
                                        <div class="col-md-4">
                                            <div class="d-flex align-items-center">
                                                <div class="flex-grow-1">
                                                    <small class="text-muted">Bid Time</small>
                                                    <p class="mb-0">@bid.BidTime.ToString("MMM dd, yyyy h:mm tt")</p>
                                                </div>
                                            </div>
                                        </div>
                                    </div>

                                    <!-- Action Buttons -->
                                    <div class="mt-3">
                                        @if (isActive)
                                        {
                                            <button class="btn btn-sm btn-outline-primary me-2">
                                                <i class="fas fa-gavel me-1"></i> Place Higher Bid
                                            </button>
                                            <button class="btn btn-sm btn-outline-secondary">
                                                <i class="fas fa-eye me-1"></i> View Auction
                                            </button>
                                        }
                                        else
                                        {
                                            <button class="btn btn-sm btn-outline-secondary">
                                                <i class="fas fa-eye me-1"></i> View Results
                                            </button>
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="text-center py-5">
                    <i class="fas fa-gavel fa-4x text-muted mb-3"></i>
                    <h5 class="text-muted">No Bids Found</h5>
                    <p class="text-muted mb-4">You haven't placed any bids yet.</p>
                    <a href="/Auctions" class="btn btn-primary">
                        <i class="fas fa-search me-1"></i> Browse Auctions
                    </a>
                </div>
            }
        </div>
    </div>
</div>

<!-- Add Bootstrap Icons -->
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">

<style>
    .card {
        border-radius: 10px;
        overflow: hidden;
    }

    .list-group-item {
        padding: 1.5rem;
        border: none;
        border-bottom: 1px solid #eee !important;
    }

        .list-group-item:last-child {
            border-bottom: none !important;
        }

    .bg-primary {
        background-color: #007bff !important;
    }

    .badge {
        font-size: 0.8rem;
        padding: 0.4rem 0.8rem;
    }

    .text-success {
        color: #28a745 !important;
    }

    .text-warning {
        color: #ffc107 !important;
    }

    .text-info {
        color: #17a2b8 !important;
    }

    .rounded-circle {
        width: 60px;
        height: 60px;
        display: flex;
        align-items: center;
        justify-content: center;
    }
</style>

