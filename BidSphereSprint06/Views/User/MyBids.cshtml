@model List<Bid>

@{
    ViewData["Title"] = "My Bids - BidSphere";
    var totalBids = ViewBag.TotalBids;
    var winningBids = ViewBag.WinningBids;
    var wonBids = ViewBag.WonBids;
    var activeBids = ViewBag.ActiveBids;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"]</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        .bid-card {
            transition: transform 0.2s;
            border-left: 4px solid transparent;
        }

            .bid-card:hover {
                transform: translateY(-2px);
            }

        .status-winning {
            border-left-color: #28a745;
        }

        .status-won {
            border-left-color: #007bff;
        }

        .status-lost {
            border-left-color: #dc3545;
        }

        .status-runnerup {
            border-left-color: #ffc107;
        }

        .bid-amount {
            font-size: 1.1rem;
            font-weight: bold;
        }
    </style>
</head>
<body class="bg-light">
    <div class="container-fluid py-4">
        <!-- Header -->
        <div class="row mb-4">
            <div class="col">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <nav aria-label="breadcrumb">
                            <ol class="breadcrumb">
                                <li class="breadcrumb-item"><a href="#" class="text-decoration-none"><i class="fas fa-home"></i> Home</a></li>
                                <li class="breadcrumb-item active" aria-current="page">My Bids</li>
                            </ol>
                        </nav>
                        <h1 class="h2 mb-1">My Bidding History</h1>
                        <p class="text-muted mb-0">Track all your bids and auction results</p>
                    </div>
                    <div class="d-flex gap-2">
                        <button class="btn btn-outline-primary">
                            <i class="fas fa-download me-2"></i>Export
                        </button>
                        <a href="@Url.Action("AllProducts", "Product")" class="btn btn-primary">
                            <i class="fas fa-gavel me-2"></i>Browse Auctions
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <!-- Stats Cards -->
        <div class="row mb-4">
            <div class="col-md-3 mb-3">
                <div class="card border-0 bg-primary text-white shadow-sm">
                    <div class="card-body text-center">
                        <i class="fas fa-gavel fa-2x mb-3"></i>
                        <h3 class="card-title">@totalBids</h3>
                        <p class="card-text">Total Bids Placed</p>
                    </div>
                </div>
            </div>
            <div class="col-md-3 mb-3">
                <div class="card border-0 bg-success text-white shadow-sm">
                    <div class="card-body text-center">
                        <i class="fas fa-trophy fa-2x mb-3"></i>
                        <h3 class="card-title">@wonBids</h3>
                        <p class="card-text">Auctions Won</p>
                    </div>
                </div>
            </div>
            <div class="col-md-3 mb-3">
                <div class="card border-0 bg-warning text-white shadow-sm">
                    <div class="card-body text-center">
                        <i class="fas fa-clock fa-2x mb-3"></i>
                        <h3 class="card-title">@winningBids</h3>
                        <p class="card-text">Currently Winning</p>
                    </div>
                </div>
            </div>
            <div class="col-md-3 mb-3">
                <div class="card border-0 bg-info text-white shadow-sm">
                    <div class="card-body text-center">
                        <i class="fas fa-hourglass-half fa-2x mb-3"></i>
                        <h3 class="card-title">@activeBids</h3>
                        <p class="card-text">Active Bids</p>
                    </div>
                </div>
            </div>
        </div>

        <!-- Bids List -->
        <div class="row">
            <div class="col-12">
                <div class="card shadow-sm">
                    <div class="card-header bg-white">
                        <div class="d-flex justify-content-between align-items-center">
                            <h5 class="card-title mb-0">My Bids</h5>
                            <div class="btn-group" role="group">
                                <button type="button" class="btn btn-outline-secondary active">All</button>
                                <button type="button" class="btn btn-outline-secondary">Active</button>
                                <button type="button" class="btn btn-outline-secondary">Won</button>
                                <button type="button" class="btn btn-outline-secondary">Lost</button>
                            </div>
                        </div>
                    </div>
                    <div class="card-body p-0">
                        @if (Model.Any())
                        {
                            <div class="list-group list-group-flush">
                                @foreach (var bid in Model)
                                {
                                    var isActive = bid.AuctionInfo.EndTime > DateTime.Now;
                                    var statusClass = bid.AuctionInfo.Status.ToLower().Replace(" ", "");

                                    <div class="list-group-item bid-card status-@statusClass">
                                        <div class="row align-items-center">
                                            <div class="col-md-2">
                                                <div class="bg-primary text-white rounded-2 text-center py-3">
                                                    <i class="fas fa-box fa-2x"></i>
                                                </div>
                                            </div>
                                            <div class="col-md-3">
                                                <h6 class="mb-1">@bid.AuctionInfo.Item.Name</h6>
                                                <small class="text-muted">
                                                    <i class="fas fa-tag me-1"></i>@bid.AuctionInfo.Item.Category
                                                </small>
                                                <br>
                                                <small class="text-muted">
                                                    <i class="fas fa-clock me-1"></i>
                                                    @if (isActive)
                                                    {
                                                        <span class="text-success">Ends @bid.AuctionInfo.EndTime.ToString("MMM dd, h:mm tt")</span>
                                                    }
                                                    else
                                                    {
                                                        <span class="text-muted">Ended @bid.AuctionInfo.EndTime.ToString("MMM dd, h:mm tt")</span>
                                                    }
                                                </small>
                                            </div>
                                            <div class="col-md-2 text-center">
                                                <div class="bid-amount text-primary">$@bid.Amount</div>
                                                <small class="text-muted">Your Bid</small>
                                            </div>
                                            <div class="col-md-2 text-center">
                                                <div class="fw-bold">$@bid.AuctionInfo.CurrentPrice</div>
                                                <small class="text-muted">Highest Bid</small>
                                            </div>
                                            <div class="col-md-2 text-center">
                                                @if (bid.AuctionInfo.Status == "Winning")
                                                {
                                                    <span class="badge bg-success fs-6">Winning</span>
                                                }
                                                else if (bid.AuctionInfo.Status == "Won")
                                                {
                                                    <span class="badge bg-primary fs-6">Won</span>
                                                }
                                                else if (bid.AuctionInfo.Status == "Runner Up")
                                                {
                                                    <span class="badge bg-warning fs-6">Runner Up</span>
                                                }
                                                else if (bid.AuctionInfo.Status == "Lost")
                                                {
                                                    <span class="badge bg-danger fs-6">Lost</span>
                                                }
                                                <br>
                                                <small class="text-muted">@bid.BidTime.ToString("MMM dd, h:mm tt")</small>
                                            </div>
                                            <div class="col-md-1 text-center">
                                                @if (isActive)
                                                {
                                                    <button class="btn btn-sm btn-outline-primary" data-bid-id="@bid.Id">
                                                        <i class="fas fa-gavel"></i> Rebid
                                                    </button>
                                                }
                                                else
                                                {
                                                    <button class="btn btn-sm btn-outline-secondary">
                                                        <i class="fas fa-eye"></i> View
                                                    </button>
                                                }
                                            </div>
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                        else
                        {
                            <div class="text-center py-5">
                                <i class="fas fa-gavel fa-4x text-muted mb-3"></i>
                                <h4 class="text-muted">No Bids Yet</h4>
                                <p class="text-muted mb-4">You haven't placed any bids yet.</p>
                                <a href="@Url.Action("AllAuctions", "Auction")" class="btn btn-primary">
                                    <i class="fas fa-gavel me-2"></i>Start Bidding
                                </a>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="https://code.jquery.com/jquery-3.7.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        $(document).ready(function() {
            $('.btn-group .btn').click(function() {
                $('.btn-group .btn').removeClass('active');
                $(this).addClass('active');

                // Filter functionality would go here
                alert('Filter would be applied in real application');
            });

            $('[data-bid-id]').click(function() {
                const bidId = $(this).data('bid-id');
                alert(`Rebidding on bid #${bidId}`);
            });
        });
    </script>
</body>
</html>