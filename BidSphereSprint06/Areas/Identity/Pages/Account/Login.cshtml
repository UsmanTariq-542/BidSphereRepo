@page
@model LoginModel

@{
    ViewData["Title"] = "Log in";
}

<div class="vh-100 d-flex justify-content-center align-items-center"
     style="background: url('/images/homePageBackground.png') no-repeat center center fixed; background-size: cover;">

    <div class="card shadow-lg p-4 bg-primary-subtle text-dark btn-dark" style="width: 400px; max-height: 90vh; overflow-y: auto; border-radius: 20px;">
        <!-- Header -->
        <h2 class="text-center fw-bold mb-2">Welcome back to BidSphere</h2>
        <p class="text-center text-muted mb-4">Login to place your first bid!</p>

        <!-- Local Account Form -->
        <form id="account" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3" role="alert"></div>

            <div class="form-floating mb-3">
                <input asp-for="Input.Email" class="form-control" autocomplete="username" aria-required="true" placeholder="name@example.com" />
                <label asp-for="Input.Email">Email</label>
                <span asp-validation-for="Input.Email" class="text-danger"></span>
            </div>

            <div class="form-floating mb-3">
                <input asp-for="Input.Password" class="form-control" autocomplete="current-password" aria-required="true" placeholder="password" />
                <label asp-for="Input.Password">Password</label>
                <span asp-validation-for="Input.Password" class="text-danger"></span>
            </div>

            <div class="form-check mb-3">
                <input class="form-check-input" asp-for="Input.RememberMe" />
                <label class="form-check-label" asp-for="Input.RememberMe">@Html.DisplayNameFor(m => m.Input.RememberMe)</label>
            </div>

            <button id="login-submit" type="submit" class="w-100 btn btn-danger py-2 rounded-3 fw-semibold shadow-sm mb-3">
                Log in
            </button>

            <div class="d-flex align-items-center my-3">
                <hr class="flex-grow-1" />
                <span class="mx-2 text-muted">OR</span>
                <hr class="flex-grow-1" />
            </div>
        </form>

        <!-- External Logins -->
        @if ((Model.ExternalLogins?.Count ?? 0) == 0)
        {
            <p class="text-muted">No external authentication providers configured.</p>
        }
        else
        {
            <form id="external-account" asp-page="./ExternalLogin" asp-route-returnUrl="@Model.ReturnUrl" method="post">
                @foreach (var provider in Model.ExternalLogins!)
                {
                    <button type="submit" name="provider" value="@provider.Name"
                            class="btn btn-secondary w-100 d-flex align-items-center justify-content-center gap-2 mb-2 btn-google"
                            title="Log in using your @provider.DisplayName account">
                        <img src="~/images/google-logo.svg" width="24" height="24" alt="Google Logo">
                        Login through @provider.DisplayName
                    </button>
                }
            </form>
        }

        <!-- Links -->
        <div class="text-center mt-2">
            <p class="mb-1"><a id="forgot-password" asp-page="./ForgotPassword" class="text-muted">Forgot your password?</a></p>
            <p class="mb-1">Don't have an account? <a asp-page="./Register" class="text-danger fw-semibold">Register here</a></p>
        </div>

    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

<style>
    /* Input focus glow */
    .form-control:focus {
        border-color: #dc3545; /* Red focus for consistency */
        box-shadow: 0 0 5px rgba(220, 53, 69, 0.5);
    }

    /* Google button hover effect */
    .btn-google:hover {
        background-color: black;
        transform: translateY(-2px);
        transition: all 0.2s ease;
    }

    /* Responsive card width */
    @@media (max-width: 576px) {
        .card

    {
        width: 90vw;
    }

    }
</style>
