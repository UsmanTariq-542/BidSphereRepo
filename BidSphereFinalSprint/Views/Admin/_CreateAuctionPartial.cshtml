@using BidSphereProject.ViewModels
@model CreateAuctionViewModel

<div class="form-container">
    <h2>Create New Auction</h2>
    <form id="auction-form" asp-action="CreateAuction" method="post">
        @Html.AntiForgeryToken()

        <!-- Product Name -->
        <div class="form-group">
            <label asp-for="Name">Product Name *</label>
            <input asp-for="Name" type="text" class="form-control" placeholder="Enter product name" required>
            <span asp-validation-for="Name" class="text-danger small"></span>
        </div>

        <!-- Category -->
        <div class="form-group">
            <label asp-for="Category">Category *</label>
            <select asp-for="Category" class="form-control" required>
                <option value="">Select Category</option>
                <option value="Fashion Outfit">Fashion Outfit</option>
                <option value="Home Appliances">Home Appliances</option>
                <option value="Laptops">Laptops</option>
                <option value="Perfumes">Perfumes</option>
                <option value="Luxury Watches">Luxury Watches</option>
                <option value="Automobiles">Automobiles</option>
                <option value="Jewelry">Jewelry</option>
            </select>
            <span asp-validation-for="Category" class="text-danger small"></span>
        </div>

        <!-- Starting Price -->
        <div class="form-group">
            <label asp-for="StartingPrice">Starting Price ($) *</label>
            <div class="input-group">
                <span class="input-group-text"></span>
                <input asp-for="StartingPrice" type="number" class="form-control"
                       min="0.01" step="0.01" placeholder="0.00" required>
            </div>
            <span asp-validation-for="StartingPrice" class="text-danger small"></span>
        </div>

        <!-- Description -->
        <div class="form-group">
            <label asp-for="Description">Description</label>
            <textarea asp-for="Description" class="form-control" rows="3"
                      placeholder="Enter auction description (optional)"></textarea>
            <span asp-validation-for="Description" class="text-danger small"></span>
        </div>

        <!-- Duration Section - 4 Fields -->
        <div class="form-group">
            <label class="d-block mb-2 fw-bold">Auction Duration *</label>
            <p class="text-muted small mb-3">Maximum duration: 30 days (1 month)</p>

            <div class="duration-container">
                <!-- Days -->
                <div class="duration-field">
                    <label asp-for="DurationDays" class="form-label small text-muted">Days</label>
                    <div class="input-group">
                        <input asp-for="DurationDays" type="number" class="form-control duration-input"
                               min="0" max="30" value="0">
                    </div>
                    <span asp-validation-for="DurationDays" class="text-danger small"></span>
                </div>

                <!-- Hours -->
                <div class="duration-field">
                    <label asp-for="DurationHours" class="form-label small text-muted">Hours</label>
                    <div class="input-group">
                        <input asp-for="DurationHours" type="number" class="form-control duration-input"
                               min="0" max="23" value="0">
                    </div>
                    <span asp-validation-for="DurationHours" class="text-danger small"></span>
                </div>

                <!-- Minutes -->
                <div class="duration-field">
                    <label asp-for="DurationMinutes" class="form-label small text-muted">Minutes</label>
                    <div class="input-group">
                        <input asp-for="DurationMinutes" type="number" class="form-control duration-input"
                               min="0" max="59" value="1">
                    </div>
                    <span asp-validation-for="DurationMinutes" class="text-danger small"></span>
                </div>

                <!-- Seconds -->
                <div class="duration-field">
                    <label asp-for="DurationSeconds" class="form-label small text-muted">Seconds</label>
                    <div class="input-group">
                        <input asp-for="DurationSeconds" type="number" class="form-control duration-input"
                               min="0" max="59" value="0">
                    </div>
                    <span asp-validation-for="DurationSeconds" class="text-danger small"></span>
                </div>
            </div>
        </div>

        <!-- Submit Button -->
        <div class="form-group mt-4">
            <button type="submit" class="btn btn-primary btn-lg w-100 py-3">
                <i class="fas fa-gavel me-2"></i>Create Auction
            </button>
        </div>
    </form>
</div>

<!-- Duration Calculation Script -->
<script>
    $(document).ready(function() {
        // Function to update duration summary
        function updateDurationSummary() {
            var days = parseInt($('#DurationDays').val()) || 0;
            var hours = parseInt($('#DurationHours').val()) || 0;
            var minutes = parseInt($('#DurationMinutes').val()) || 0;
            var seconds = parseInt($('#DurationSeconds').val()) || 0;

            // Build human readable string
            var parts = [];
            if (days > 0) parts.push(days + " day" + (days > 1 ? "s" : ""));
            if (hours > 0) parts.push(hours + " hour" + (hours > 1 ? "s" : ""));
            if (minutes > 0) parts.push(minutes + " minute" + (minutes > 1 ? "s" : ""));
            if (seconds > 0) parts.push(seconds + " second" + (seconds > 1 ? "s" : ""));

            if (parts.length === 0) {
                parts.push("0 minutes");
            }

            var durationText = parts.join(", ");
            $('#total-duration-text').text(durationText);

            // Calculate totals
            var totalMinutes = (days * 24 * 60) + (hours * 60) + minutes + (seconds > 0 ? 1 : 0);
            var totalHours = (days * 24) + hours + (minutes / 60) + (seconds / 3600);

            $('#total-minutes').text(totalMinutes + " min");
            $('#total-hours').text(totalHours.toFixed(2) + " hrs");

            // Calculate end time
            var now = new Date();
            var endTime = new Date(now);
            endTime.setDate(endTime.getDate() + days);
            endTime.setHours(endTime.getHours() + hours);
            endTime.setMinutes(endTime.getMinutes() + minutes);
            endTime.setSeconds(endTime.getSeconds() + seconds);

            $('#end-time').text(formatDate(endTime));

            // Validate max duration (30 days = 43,200 minutes)
            if (totalMinutes > 43200) {
                $('#duration-summary').addClass('border-danger');
                $('#total-duration-text').addClass('text-danger');
                showWarning('Duration exceeds 30 days limit!');
            } else {
                $('#duration-summary').removeClass('border-danger');
                $('#total-duration-text').removeClass('text-danger');
            }
        }

        // Format date for display
        function formatDate(date) {
            var options = {
                month: 'short',
                day: 'numeric',
                year: 'numeric',
                hour: '2-digit',
                minute: '2-digit'
            };
            return date.toLocaleDateString('en-US', options) + ' ' +
                   date.toLocaleTimeString('en-US', {hour: '2-digit', minute:'2-digit'});
        }

        // Show warning message
        function showWarning(message) {
            var warning = $('.duration-warning');
            if (warning.length === 0) {
                warning = $('<div class="alert alert-warning duration-warning mt-2"></div>');
                $('.duration-summary').after(warning);
            }
            warning.html('<i class="fas fa-exclamation-triangle me-2"></i>' + message);
        }

        // Hide warning
        function hideWarning() {
            $('.duration-warning').remove();
        }

        // Update summary when duration inputs change
        $('.duration-input').on('input', function() {
            updateDurationSummary();
            hideWarning();
        });

        // Preset duration buttons
        $('.preset-btn').click(function() {
            $('#DurationDays').val($(this).data('days'));
            $('#DurationHours').val($(this).data('hours'));
            $('#DurationMinutes').val($(this).data('minutes'));
            $('#DurationSeconds').val(0);

            updateDurationSummary();
            hideWarning();
        });

        // Auto-calculate: If days > 0, ensure hours < 24
        $('#DurationDays').on('input', function() {
            var days = parseInt($(this).val()) || 0;
            var hours = parseInt($('#DurationHours').val()) || 0;

            if (days > 0 && hours >= 24) {
                $('#DurationHours').val(0);
                showWarning('Hours reset to 0 when days are specified');
            }
        });

        // Validate total duration on form submit
        $('#auction-form').submit(function(e) {
            var days = parseInt($('#DurationDays').val()) || 0;
            var hours = parseInt($('#DurationHours').val()) || 0;
            var minutes = parseInt($('#DurationMinutes').val()) || 0;
            var seconds = parseInt($('#DurationSeconds').val()) || 0;

            var totalMinutes = (days * 24 * 60) + (hours * 60) + minutes + (seconds > 0 ? 1 : 0);

            // Minimum validation (at least 1 minute)
            if (totalMinutes < 1) {
                e.preventDefault();
                showNotification('Auction duration must be at least 1 minute', 'error');
                return false;
            }

            // Maximum validation (30 days = 43,200 minutes)
            if (totalMinutes > 43200) {
                e.preventDefault();
                showNotification('Auction cannot exceed 30 days (1 month)', 'error');
                return false;
            }

            // Validate hours when days are set
            if (days > 0 && hours >= 24) {
                e.preventDefault();
                showNotification('Hours must be 0-23 when days are specified', 'error');
                return false;
            }

            return true;
        });

        // Form submission via AJAX
        $('#auction-form').submit(function(e) {
            e.preventDefault();

            if (!$(this).valid()) {
                return false;
            }

            var formData = $(this).serialize();

            // Show loading state
            var submitBtn = $(this).find('button[type="submit"]');
            var originalText = submitBtn.html();
            submitBtn.prop('disabled', true).html('<i class="fas fa-spinner fa-spin me-2"></i>Creating...');

            $.ajax({
                url: $(this).attr('action'),
                type: 'POST',
                data: formData,
                headers: {
                    'RequestVerificationToken': $('input[name="__RequestVerificationToken"]').val()
                },
                success: function(response) {
                    if (response.success) {
                        showNotification(response.message, 'success');
                        // Reset form
                        $('#auction-form')[0].reset();
                        // Reset to default values
                        $('#DurationDays').val(0);
                        $('#DurationHours').val(0);
                        $('#DurationMinutes').val(1);
                        $('#DurationSeconds').val(0);
                        updateDurationSummary();
                    } else {
                        showNotification(response.message, 'error');
                    }
                },
                error: function(xhr) {
                    var message = 'Error creating auction';
                    if (xhr.responseJSON && xhr.responseJSON.message) {
                        message = xhr.responseJSON.message;
                    }
                    showNotification(message, 'error');
                },
                complete: function() {
                    submitBtn.prop('disabled', false).html(originalText);
                }
            });
        });

        function showNotification(message, type) {
            // Remove existing notifications
            $('.alert').not('.duration-warning').alert('close');

            var alertClass = type === 'success' ? 'alert-success' : 'alert-danger';
            var icon = type === 'success' ? 'fa-check-circle' : 'fa-exclamation-circle';

            var notification = $(
                '<div class="alert ' + alertClass + ' alert-dismissible fade show mt-3" role="alert">' +
                '<i class="fas ' + icon + ' me-2"></i>' +
                message +
                '<button type="button" class="btn-close" data-bs-dismiss="alert"></button>' +
                '</div>'
            );

            $('.form-container').prepend(notification);

            if (type === 'success') {
                setTimeout(function() {
                    notification.alert('close');
                }, 5000);
            }
        }

        // Initialize summary on page load
        updateDurationSummary();
    });
</script>

<style>
    .duration-container {
        display: flex;
        gap: 15px;
        flex-wrap: wrap;
    }

    .duration-field {
        flex: 1;
        min-width: 140px;
    }

    .duration-input {
        text-align: center;
    }

    .input-group-text {
        min-width: 60px;
        justify-content: center;
    }

    .duration-summary {
        background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
    }

    .quick-duration .btn-group {
        gap: 5px;
    }

    .quick-duration .btn {
        margin-bottom: 5px;
        border-radius: 5px !important;
    }

    .custom-example {
        background-color: #fff3cd;
        border-left: 4px solid #ffc107;
        padding: 10px;
        border-radius: 4px;
    }

        .custom-example code {
            background-color: #f8f9fa;
            padding: 2px 5px;
            border-radius: 3px;
            font-size: 0.9em;
        }

    .btn-primary {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        border: none;
        transition: all 0.3s ease;
    }

        .btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(0,0,0,0.1);
        }

    /* Responsive adjustments */

    
    @@media (max-width: 768px) {
        .duration-field

    {
        min-width: calc(50% - 15px);
    }

    }

    @@media(max-width: 576px) {
        .duration-field

    {
        min-width: 100%;
    }


}
</style>