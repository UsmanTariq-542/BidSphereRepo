@using BidSphereProject.ViewModels
@model DashboardViewModel

@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>BidSphere - Admin Dashboard</title>
    <style>
        :root {
            --primary: #4361ee;
            --secondary: #3f37c9;
            --success: #4cc9f0;
            --danger: #f72585;
            --warning: #f8961e;
            --info: #4895ef;
            --light: #f8f9fa;
            --dark: #212529;
            --sidebar-width: 250px;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }

        body {
            display: flex;
            background-color: #f5f7fb;
            color: var(--dark);
        }

        /* Sidebar Styles */
        .sidebar {
            width: var(--sidebar-width);
            height: 100vh;
            background: linear-gradient(to bottom, var(--primary), var(--secondary));
            color: white;
            position: fixed;
            transition: all 0.3s;
            box-shadow: 3px 0 10px rgba(0, 0, 0, 0.1);
            z-index: 1000;
        }

        .sidebar-header {
            padding: 20px;
            text-align: center;
            border-bottom: 1px solid rgba(255, 255, 255, 0.1);
        }

            .sidebar-header h2 {
                font-size: 1.5rem;
                margin-bottom: 5px;
            }

        .sidebar-menu {
            padding: 15px 0;
        }

            .sidebar-menu ul {
                list-style: none;
            }

            .sidebar-menu li {
                padding: 12px 20px;
                transition: all 0.3s;
            }

            .sidebar-menu li:hover {
                background-color: rgba(255, 255, 255, 0.1);
                cursor: pointer;
            }

            .sidebar-menu li.active {
                background-color: rgba(255, 255, 255, 0.2);
                border-left: 4px solid white;
            }

            .sidebar-menu i {
                margin-right: 10px;
                width: 20px;
                text-align: center;
            }

            /* Style for links inside sidebar items */
            .sidebar-menu li a {
                color: white !important;
                text-decoration: none;
                display: flex;
                align-items: center;
            }

            .sidebar-menu li a i {
                margin-right: 10px;
                width: 20px;
                text-align: center;
            }

            /* Keep hover effect for all items */
            .sidebar-menu li:hover {
                background-color: rgba(255, 255, 255, 0.1);
                cursor: pointer;
            }

            .sidebar-menu li.active {
                background-color: rgba(255, 255, 255, 0.2);
                border-left: 4px solid white;
            }

            /* Make sure the link takes full width */
            .sidebar-menu li a {
                width: 100%;
                padding: 12px 20px;
            }

        /* Main Content Styles */
        .main-content {
            flex: 1;
            margin-left: var(--sidebar-width);
            padding: 20px;
            transition: all 0.3s;
        }

        .header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 30px;
            padding-bottom: 15px;
            border-bottom: 1px solid #e0e0e0;
        }

            .header h1 {
                color: var(--primary);
            }

        .user-info {
            display: flex;
            align-items: center;
        }

            .user-info img {
                width: 40px;
                height: 40px;
                border-radius: 50%;
                margin-right: 10px;
            }

        /* Dashboard Stats */
        .stats-container {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
            gap: 20px;
            margin-bottom: 30px;
        }

        .stat-card {
            background: white;
            border-radius: 10px;
            padding: 20px;
            box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
            display: flex;
            align-items: center;
            transition: transform 0.3s;
        }

            .stat-card:hover {
                transform: translateY(-5px);
            }

        .stat-icon {
            width: 60px;
            height: 60px;
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin-right: 15px;
            font-size: 24px;
            color: white;
        }

        .stat-info h3 {
            font-size: 1.8rem;
            margin-bottom: 5px;
        }

        .stat-info p {
            color: #6c757d;
            font-size: 0.9rem;
        }

        /* Form Styles */
        .form-container {
            background: white;
            border-radius: 10px;
            padding: 25px;
            box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
            margin-bottom: 30px;
        }

        .form-group {
            margin-bottom: 20px;
        }

            .form-group label {
                display: block;
                margin-bottom: 8px;
                font-weight: 500;
            }

        .form-control {
            width: 100%;
            padding: 10px 15px;
            border: 1px solid #ddd;
            border-radius: 5px;
            font-size: 1rem;
            transition: border 0.3s;
        }

            .form-control:focus {
                border-color: var(--primary);
                outline: none;
            }

        .btn {
            padding: 10px 20px;
            border: none;
            border-radius: 5px;
            cursor: pointer;
            font-size: 1rem;
            transition: all 0.3s;
        }

        .btn-primary {
            background-color: var(--primary);
            color: white;
        }

            .btn-primary:hover {
                background-color: var(--secondary);
            }

        .btn-danger {
            background-color: var(--danger);
            color: white;
        }

            .btn-danger:hover {
                background-color: #d11466;
            }

        /* Table Styles */
        .table-container {
            background: white;
            border-radius: 10px;
            overflow: hidden;
            box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
            margin-bottom: 30px;
        }

        table {
            width: 100%;
            border-collapse: collapse;
        }

        thead {
            background-color: var(--primary);
            color: white;
        }

        th, td {
            padding: 15px;
            text-align: left;
            border-bottom: 1px solid #e0e0e0;
        }

        tbody tr:hover {
            background-color: #f8f9fa;
        }

        .badge {
            padding: 5px 10px;
            border-radius: 20px;
            font-size: 0.8rem;
            font-weight: 500;
        }

        .badge-success {
            background-color: #e7f7ef;
            color: #1ea97c;
        }

        .badge-danger {
            background-color: #fde8e8;
            color: #f05252;
        }

        .badge-warning {
            background-color: #fef5e7;
            color: #f59e0b;
        }

        .timer {
            font-family: 'Courier New', monospace;
            font-weight: bold;
            color: var(--danger);
        }

        .action-buttons {
            display: flex;
            gap: 10px;
        }

        /* Section Management */
        .section {
            display: none;
        }

            .section.active {
                display: block;
            }

        /* Filter Styles */
        .filter-container {
            display: flex;
            justify-content: space-between;
            margin-bottom: 20px;
            align-items: center;
        }

        .category-filter {
            display: flex;
            gap: 10px;
        }

        .filter-btn {
            padding: 8px 15px;
            background: white;
            border: 1px solid #ddd;
            border-radius: 5px;
            cursor: pointer;
            transition: all 0.3s;
        }

        /* Dashboard.cshtml ke style section mein (~line 200 ke baad) */
        /* Improved Modal Styling */
        .modal-overlay {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: rgba(0, 0, 0, 0.6);
            backdrop-filter: blur(4px);
            display: flex;
            align-items: center;
            justify-content: center;
            z-index: 1000;
            animation: fadeIn 0.2s ease-out;
        }

        @@keyframes fadeIn {
            from

        {
            opacity: 0;
        }

        to {
            opacity: 1;
        }

        }

        @@keyframes slideUp {
            from

        {
            transform: translateY(30px);
            opacity: 0;
        }

        to {
            transform: translateY(0);
            opacity: 1;
        }

        }

        @@keyframes fadeOut {
            from

        {
            opacity: 1;
        }

        to {
            opacity: 0;
        }

        }

        .modal-content {
            background: white;
            border-radius: 16px;
            width: 90%;
            max-width: 480px;
            box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 10px 10px -5px rgba(0, 0, 0, 0.04);
            overflow: hidden;
            animation: slideUp 0.3s ease-out;
        }

        .modal-header {
            background: linear-gradient(135deg, var(--primary), var(--secondary));
            color: white;
            padding: 24px 28px;
            position: relative;
        }

            .modal-header h3 {
                margin: 0;
                font-size: 1.5rem;
                font-weight: 600;
                display: flex;
                align-items: center;
                gap: 12px;
            }

        .modal-close {
            position: absolute;
            top: 20px;
            right: 20px;
            background: rgba(255, 255, 255, 0.2);
            border: none;
            color: white;
            width: 32px;
            height: 32px;
            border-radius: 50%;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: all 0.2s;
        }

            .modal-close:hover {
                background: rgba(255, 255, 255, 0.3);
                transform: rotate(90deg);
            }

        .modal-body {
            padding: 28px;
        }

        .product-info {
            background: linear-gradient(135deg, #f0f9ff 0%, #e0f2fe 100%);
            border-left: 4px solid var(--primary);
            padding: 16px 20px;
            border-radius: 8px;
            margin-bottom: 24px;
        }

            .product-info p {
                margin: 0;
                color: #1e40af;
                font-weight: 500;
            }

        .form-section label {
            display: block;
            font-weight: 600;
            color: #374151;
            margin-bottom: 12px;
        }

        .time-inputs {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 12px;
            margin-bottom: 12px;
        }

        .time-input-group {
            text-align: center;
        }

        .time-input {
            width: 100%;
            padding: 14px 12px;
            border: 2px solid #e5e7eb;
            border-radius: 10px;
            font-size: 1.1rem;
            font-weight: 600;
            text-align: center;
            transition: all 0.2s;
            background: #f9fafb;
        }

            .time-input:focus {
                outline: none;
                border-color: var(--primary);
                background: white;
                box-shadow: 0 0 0 3px rgba(67, 97, 238, 0.1);
            }

        .time-label {
            font-size: 0.85rem;
            color: #6b7280;
            font-weight: 500;
            margin-top: 8px;
        }

        .preview-section {
            background: #f0fdf4;
            border: 2px dashed #86efac;
            border-radius: 10px;
            padding: 16px;
            text-align: center;
            margin-bottom: 24px;
        }

        .preview-time {
            font-size: 1.5rem;
            font-weight: 700;
            color: var(--success);
            font-family: 'Courier New', monospace;
        }

        .info-box {
            background: #fef3c7;
            border-left: 4px solid var(--warning);
            padding: 12px 16px;
            border-radius: 8px;
            display: flex;
            gap: 10px;
        }

            .info-box p {
                margin: 0;
                color: #92400e;
                font-size: 0.9rem;
            }

        .modal-footer {
            padding: 20px 28px;
            background: #f9fafb;
            display: flex;
            gap: 12px;
            justify-content: flex-end;
            border-top: 1px solid #e5e7eb;
        }
        
        /* Text Colors */
        .text-success {
            color: #28a745 !important;
        }

        .text-warning {
            color: #ffc107 !important;
        }

        .text-danger {
            color: #dc3545 !important;
        }

        /* Button Styling */
        .btn-sm {
            padding: 5px 10px;
            font-size: 0.875rem;
        }

        /* Spacing for time inputs */
        .d-flex.gap-2 > * {
            margin-right: 10px;
        }

            .d-flex.gap-2 > *:last-child {
                margin-right: 0;
            }

            .filter-btn.active {
                background-color: var(--primary);
                color: white;
                border-color: var(--primary);
            }

        /* Responsive Design */
        @@media (max-width: 768px) {
            .sidebar

        {
            width: 70px;
            overflow: hidden;
        }

        .sidebar-header h2, .sidebar-menu span {
            display: none;
        }

        .sidebar-menu li {
            text-align: center;
            padding: 15px 0;
        }

        .sidebar-menu i {
            margin-right: 0;
            font-size: 1.2rem;
        }

        .main-content {
            margin-left: 70px;
        }

        .stats-container {
            grid-template-columns: 1fr;
        }

        .filter-container {
            flex-direction: column;
            gap: 15px;
            align-items: flex-start;
        }

        }
    </style>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body>
    <!-- Sidebar -->
    <div class="sidebar">
        <div class="sidebar-header">
            <h2>BidSphere Admin</h2>
            <p>Administration Panel</p>
        </div>
        <div class="sidebar-menu">
            <ul>
                <li class="active" data-section="dashboard">
                    <i class="fas fa-tachometer-alt"></i>
                    <span>Dashboard</span>
                </li>
                <li data-section="create-auction">
                    <i class="fas fa-plus-circle"></i>
                    <span>Create Auction</span>
                </li>

                <li data-section="live-auctions">
                    <i class="fas fa-eye"></i>
                    <span>View Live Auctions</span>
                </li>
                <!-- Send notification -->
                <li style="height: 49px; padding: 12px 20px;">
                    <a href="/Notification/SendNotification"
                       style="display: flex; align-items: center; color: white; text-decoration: none; height: 100%; padding: 0;">
                        <i class="fas fa-bullhorn" style="margin-right: 10px; width: 20px; text-align: center;"></i>
                        <span>Send Notification</span>
                    </a>
                </li>

            </ul>
        </div>
    </div>

    <!-- Main Content -->
    <div class="main-content">
        <div class="header">
            <h1 id="section-title">Dashboard</h1>
            <div class="user-info">
                <img src="https://ui-avatars.com/api/?name=Admin+User&background=4361ee&color=fff" alt="Admin User">
                <span>Admin</span>
            </div>
        </div>

        <!-- Dashboard Section -->
        <div id="dashboard" class="section active">
            <div class="stats-container">
                <div class="stat-card">
                    <div class="stat-icon" style="background-color: var(--primary);">
                        <i class="fas fa-gavel"></i>
                    </div>
                    <div class="stat-info">
                        <h3 id="live-auctions-count">@Model.LiveAuctionsCount</h3>
                        <p>Live Auctions</p>
                    </div>
                </div>
                <div class="stat-card">
                    <div class="stat-icon" style="background-color: var(--success);">
                        <i class="fas fa-list"></i>
                    </div>
                    <div class="stat-info">
                        <h3 id="total-bidded-auctions">@Model.TotalBids</h3>
                        <p>Total Bids Placed</p>
                    </div>
                </div>
                <div class="stat-card">
                    <div class="stat-icon" style="background-color: var(--warning);">
                        <i class="fas fa-users"></i>
                    </div>
                    <div class="stat-info">
                        <h3 id="total-registered-users">@Model.TotalRegisteredUsers</h3>
                        <p>Registered Users</p>
                    </div>
                </div>
                <div class="stat-card">
                    <div class="stat-icon" style="background-color: var(--info);">
                        <i class="fas fa-dollar-sign"></i>
                    </div>
                    <div class="stat-info">
                        <h3 id="revenue-generated">@Model.RevenueGenerated</h3>
                        <p>Revenue Generated</p>
                    </div>
                </div>
            </div>

            <!-- Done till yet -->
            <div class="table-container">
                <h2 style="padding: 20px 20px 0;">Recent Bid Activities</h2>
                <table>
                    <thead>
                        <tr>
                            <th>Auction</th>
                            <th>Bidder</th>
                            <th>Action</th>
                            <th>Bid Amount</th>
                            <th>Time</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var activity in Model.RecentBidActivities)
                        {
                            <tr>
                                <td>@activity.AuctionName</td>
                                <td>@activity.BidderUsername</td>
                                <td>@activity.Action</td>
                                <td>@activity.BidAmount</td>
                                <td>@activity.TimeAgo</td>
                            </tr>
                        }

                    </tbody>
                </table>
            </div>
        </div>

        <!-- Create Auction Section -->
        <div id="create-auction" class="section">
            <!-- This will load the partial view -->
            <div id="create-auction-content">
                @await Html.PartialAsync("_CreateAuctionPartial", new CreateAuctionViewModel())
            </div>
        </div>

        <!-- Create Auction Section -->
        <div id="create-auction" class="section">
            <!-- This will load the partial view -->
            <div id="create-auction-content">
                @await Html.PartialAsync("_CreateAuctionPartial", new CreateAuctionViewModel())
            </div>
        </div>

        <!-- Create Auction Section -->
        <div id="create-auction" class="section">
            <div id="create-auction-content">
                @await Html.PartialAsync("_CreateAuctionPartial", new CreateAuctionViewModel())
            </div>
        </div>

        <!-- Live Auctions Section -->
        <div id="live-auctions" class="section">
            <div class="table-container">
                <h2 style="padding: 20px 20px 0;">Live Auctions</h2>
                <table>
                    <thead>
                        <tr>
                            <th>Product Name</th>
                            <th>Category</th>
                            <th>Starting Price</th>
                            <th>Current Price</th>
                            <th>End Time</th>
                            <th>Action</th>
                        </tr>
                    </thead>
                    <tbody id="live-auctions-body">
                        <tr>
                            <td colspan="6" style="text-align: center; padding: 40px;">
                                <i class="fas fa-spinner fa-spin"></i> Loading auctions...
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <script>
        // Store current active section
        let currentSection = 'dashboard';

        // Sidebar navigation
        document.querySelectorAll('.sidebar-menu li').forEach(item => {
            item.addEventListener('click', function(e) {
                // Check if the item has a link (like Send Notification)
                const link = this.querySelector('a');

                if (link && link.getAttribute('href') !== '#') {
                    // It's a link to another page, let it navigate naturally
                    return;
                }

                // Otherwise, handle as section switching
                e.preventDefault();

                // Remove active class from all items
                document.querySelectorAll('.sidebar-menu li').forEach(li => {
                    li.classList.remove('active');
                });

                // Add active class to clicked item
                this.classList.add('active');

                // Hide all sections
                document.querySelectorAll('.section').forEach(section => {
                    section.classList.remove('active');
                });

                // Show selected section
                const sectionId = this.getAttribute('data-section');
                document.getElementById(sectionId).classList.add('active');

                // Update current section
                currentSection = sectionId;

                // Update section title
                const spanText = this.querySelector('span');
                if (spanText) {
                    document.getElementById('section-title').textContent = spanText.textContent;
                }

                // Initialize the newly shown section
                initializeSection(sectionId);
            });
        });

        // Initialize specific section based on ID
        function initializeSection(sectionId) {
            switch(sectionId) {
                case 'dashboard':
                    initDashboard();
                    break;
                case 'create-auction':
                    initCreateAuction();
                    break;
                case 'live-auctions':
                    initLiveAuctions();
                    break;
            }
        }

        // Initialize dashboard section
        function initDashboard() {
            console.log('Initializing Dashboard...');

            // Populate live auctions table
            if (typeof filterAuctions === 'function') {
                filterAuctions('all');
            }

            // Start timer updates
            if (typeof updateTimers === 'function') {
                setInterval(updateTimers, 1000);
            }

            // You can also load dashboard data via AJAX here
            loadDashboardData();
        }

        // Initialize create auction section
        function initCreateAuction() {
            console.log('Initializing Create Auction Form...');

            // Wait a bit for the section to be fully rendered
            setTimeout(() => {
                const auctionForm = document.getElementById('auction-form');

                if (auctionForm) {
                    // Remove any existing event listeners first
                    const newForm = auctionForm.cloneNode(true);
                    auctionForm.parentNode.replaceChild(newForm, auctionForm);

                    // Add new event listener
                    newForm.addEventListener('submit', function(e) {
                        e.preventDefault();
                        handleAuctionFormSubmit(this);
                    });

                    console.log('Auction form event listener attached');
                } else {
                    console.error('Auction form not found!');
                }
            }, 50);
        }

        // Handle auction form submission
        async function handleAuctionFormSubmit(form) {
            // Show loading state
            const submitBtn = form.querySelector('button[type="submit"]');
            const originalText = submitBtn.innerHTML;
            submitBtn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Creating...';
            submitBtn.disabled = true;

            try {
                // Get form data
                const formData = new FormData(form);

                // If you're using AJAX (recommended)
                const response = await fetch(form.action, {
                    method: 'POST',
                    headers: {
                        'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value
                    },
                    body: formData
                });

                const result = await response.json();

                if (result.success) {
                    // Show success message
                    showNotification(result.message, 'success');

                    // Reset form
                    form.reset();

                    // Reset duration fields to defaults
                    if (document.getElementById('DurationDays')) {
                        document.getElementById('DurationDays').value = 0;
                        document.getElementById('DurationHours').value = 0;
                        document.getElementById('DurationMinutes').value = 1;
                        document.getElementById('DurationSeconds').value = 0;
                    }

                    // Update duration summary if function exists
                    if (typeof updateDurationSummary === 'function') {
                        updateDurationSummary();
                    }

                    // Optional: Switch back to dashboard
                    // switchToSection('dashboard');
                } else {
                    showNotification(result.message || 'Error creating auction', 'error');

                    // Show validation errors if any
                    if (result.errors) {
                        result.errors.forEach(error => {
                            showNotification(error, 'error');
                        });
                    }
                }
            } catch (error) {
                console.error('Error:', error);
                showNotification('An error occurred. Please try again.', 'error');
            } finally {
                // Restore button
                submitBtn.innerHTML = originalText;
                submitBtn.disabled = false;
            }
        }

        // Load dashboard data via AJAX
        async function loadDashboardData() {
            try {
                const response = await fetch('/Admin/GetDashboardStats');
                const data = await response.json();

                // Update dashboard stats
                if (data.liveAuctionsCount !== undefined) {
                    document.getElementById('live-auctions-count').textContent = data.liveAuctionsCount;
                }
                if (data.totalBids !== undefined) {
                    document.getElementById('total-bids').textContent = data.totalBids;
                }
                if (data.totalRegisteredUsers !== undefined) {
                    document.getElementById('total-registered-users').textContent = data.totalRegisteredUsers;
                }
                if (data.revenueGenerated !== undefined) {
                    document.getElementById('revenue-generated').textContent = '$' + data.revenueGenerated.toLocaleString();
                }
            } catch (error) {
                console.error('Error loading dashboard data:', error);
            }
        }

                function initLiveAuctions() {
            console.log('Loading live auctions...');
            loadLiveAuctions();

            // Auto-refresh every 30 seconds
            setInterval(updateLiveAuctionTimers, 1000);
        }

        async function loadLiveAuctions() {
            try {
                const response = await fetch('/Admin/GetLiveAuctions');
                const auctions = await response.json();
                renderLiveAuctions(auctions);
            } catch (error) {
                console.error('Error loading auctions:', error);
                document.getElementById('live-auctions-body').innerHTML = `
                    <tr>
                        <td colspan="6" style="text-align: center; padding: 40px; color: var(--danger);">
                            <i class="fas fa-exclamation-circle"></i> Failed to load auctions
                        </td>
                    </tr>
                `;
            }
        }

        function renderLiveAuctions(auctions) {
            const tbody = document.getElementById('live-auctions-body');

            if (!auctions || auctions.length === 0) {
                tbody.innerHTML = `
                    <tr>
                        <td colspan="6" style="text-align: center; padding: 40px;">
                            <i class="fas fa-info-circle"></i> No live auctions available
                        </td>
                    </tr>
                `;
                return;
            }

            let html = '';

            auctions.forEach(auction => {
                const endTime = new Date(auction.endTime);
                const now = new Date();
                const diffMs = endTime - now;

                let timeRemaining = 'Ended';
                let timeClass = 'text-danger';

                if (diffMs > 0) {
                    const days = Math.floor(diffMs / (1000 * 60 * 60 * 24));
                    const hours = Math.floor((diffMs % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
                    const minutes = Math.floor((diffMs % (1000 * 60 * 60)) / (1000 * 60));
                    timeRemaining = `${days}d ${hours}h ${minutes}m`;

                    // Color coding
                    if (days === 0 && hours < 24) {
                        timeClass = 'text-danger'; // Less than 1 day
                    } else if (days < 3) {
                        timeClass = 'text-warning'; // Less than 3 days
                    } else {
                        timeClass = 'text-success'; // More than 3 days
                    }
                }

                html += `
                    <tr>
                        <td>${auction.productName}</td>
                        <td>${auction.category}</td>
                        <td>$${auction.startingPrice.toFixed(2)}</td>
                        <td><strong>$${auction.currentPrice.toFixed(2)}</strong></td>
                        <td class="${timeClass}" data-end-time="${auction.endTime}">
                            ${timeRemaining}
                        </td>
                        <td>
                            <button class="btn btn-sm btn-warning edit-endtime"
                                    onclick="showEditModal(${auction.auctionId}, '${auction.productName.replace(/'/g, "\\'")}')">
                                <i class="fas fa-clock"></i> Edit Time
                            </button>
                        </td>
                    </tr>
                `;
            });

            tbody.innerHTML = html;
        }

        // Timer update
        function updateLiveAuctionTimers() {
            document.querySelectorAll('[data-end-time]').forEach(cell => {
                const endTime = new Date(cell.getAttribute('data-end-time'));
                const now = new Date();
                const diffMs = endTime - now;

                if (diffMs <= 0) {
                    cell.textContent = 'Ended';
                    cell.className = 'text-danger';
                    return;
                }

                const days = Math.floor(diffMs / (1000 * 60 * 60 * 24));
                const hours = Math.floor((diffMs % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
                const minutes = Math.floor((diffMs % (1000 * 60 * 60)) / (1000 * 60));
                cell.textContent = `${days}d ${hours}h ${minutes}m`;
            });
        }

        function showEditModal(auctionId, productName) {
            const modalHTML = `
                <div class="modal-overlay" onclick="closeModal(event)">
                    <div class="modal-content" onclick="event.stopPropagation()">
                        <div class="modal-header">
                            <h3>
                                <i class="fas fa-clock"></i>
                                Set New End Time
                            </h3>
                            <button class="modal-close" onclick="closeModal(event)">
                                <i class="fas fa-times"></i>
                            </button>
                        </div>

                        <div class="modal-body">
                            <div class="product-info">
                                <p><i class="fas fa-tag"></i> <strong>${productName}</strong></p>
                            </div>

                            <div class="form-section">
                                <label>Enter duration to extend auction:</label>
                                <div class="time-inputs">
                                    <div class="time-input-group">
                                        <input type="number" id="editDays" class="time-input"
                                               min="0" value="1" oninput="validatePositive(this); updatePreview()">
                                        <div class="time-label">DAYS</div>
                                    </div>
                                    <div class="time-input-group">
                                        <input type="number" id="editHours" class="time-input"
                                               min="0" max="23" value="0" oninput="validatePositive(this); updatePreview()">
                                        <div class="time-label">HOURS</div>
                                    </div>
                                    <div class="time-input-group">
                                        <input type="number" id="editMinutes" class="time-input"
                                               min="0" max="59" value="0" oninput="validatePositive(this); updatePreview()">
                                        <div class="time-label">MINUTES</div>
                                    </div>
                                </div>
                            </div>

                            <div class="preview-section">
                                <p style="margin: 0 0 8px 0; color: #166534; font-size: 0.9rem;">
                                    <i class="fas fa-calendar-check"></i> New End Time
                                </p>
                                <div class="preview-time" id="previewTime">1d 0h 0m from now</div>
                            </div>

                            <div class="info-box">
                                <i class="fas fa-info-circle"></i>
                                <p>The auction will end after the specified duration from the current time.</p>
                            </div>
                        </div>

                        <div class="modal-footer">
                            <button class="btn btn-secondary" onclick="closeModal(event)">
                                <i class="fas fa-times"></i> Cancel
                            </button>
                            <button class="btn btn-primary" onclick="saveNewTime(${auctionId})">
                                <i class="fas fa-check"></i> Update Time
                            </button>
                        </div>
                    </div>
                </div>
            `;

            document.body.insertAdjacentHTML('beforeend', modalHTML);
            updatePreview();
        }

        function updatePreview() {
            const days = Math.max(0, parseInt(document.getElementById('editDays')?.value) || 0);
            const hours = Math.max(0, Math.min(23, parseInt(document.getElementById('editHours')?.value) || 0));
            const minutes = Math.max(0, Math.min(59, parseInt(document.getElementById('editMinutes')?.value) || 0));

            const previewEl = document.getElementById('previewTime');
            if (previewEl) {
                if (days === 0 && hours === 0 && minutes === 0) {
                    previewEl.textContent = 'Please enter a valid time';
                    previewEl.style.color = '#ef4444';
                } else {
                    previewEl.textContent = `${days}d ${hours}h ${minutes}m from now`;
                    previewEl.style.color = '#10b981';
                }
            }
        }

        // Validation function
        function validatePositive(input) {
            if (input.value < 0) {
                input.value = 0;
            }
        }

        function closeModal(event) {
            event?.stopPropagation();
            const modal = document.querySelector('.modal-overlay');
            if (modal) {
                modal.style.animation = 'fadeOut 0.2s ease-out';
                setTimeout(() => modal.remove(), 200);
            }
        }

        async function saveNewTime(auctionId) {
            const daysInput = document.getElementById('editDays');
            const hoursInput = document.getElementById('editHours');
            const minutesInput = document.getElementById('editMinutes');

            // Force positive values
            const days = Math.max(0, parseInt(daysInput.value) || 0);
            const hours = Math.max(0, Math.min(23, parseInt(hoursInput.value) || 0));
            const minutes = Math.max(0, Math.min(59, parseInt(minutesInput.value) || 0));

            // Update inputs with corrected values
            daysInput.value = days;
            hoursInput.value = hours;
            minutesInput.value = minutes;

            // Check if all are zero
            if (days === 0 && hours === 0 && minutes === 0) {
                alert('Please enter a valid time (minimum 1 minute)');
                return;
            }

            // Also validate on server side
            if (days < 0 || hours < 0 || minutes < 0) {
                alert('Time values cannot be negative');
                return;
            }

            if (hours > 23) {
                alert('Hours cannot be more than 23');
                return;
            }

            if (minutes > 59) {
                alert('Minutes cannot be more than 59');
                return;
            }

            // Calculate new end time
            const now = new Date();
            const msToAdd = (days * 24 * 60 * 60 * 1000) +
                           (hours * 60 * 60 * 1000) +
                           (minutes * 60 * 1000);
            const newEndTime = new Date(now.getTime() + msToAdd).toISOString();

            try {
                const response = await fetch('/Admin/UpdateEndTime', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value
                    },
                    body: JSON.stringify({
                        auctionId: auctionId,
                        newEndTime: newEndTime
                    })
                });

                const result = await response.json();

                if (result.success) {
                    alert('End time updated successfully!');
                    closeModal();
                    loadLiveAuctions();
                } else {
                    alert(result.message);
                }
            } catch (error) {
                alert('Error updating time');
            }
        }

        // Show notification
        function showNotification(message, type) {
            // Remove existing notifications
            const existingAlerts = document.querySelectorAll('.alert-dismissible');
            existingAlerts.forEach(alert => {
                alert.remove();
            });

            const alertClass = type === 'success' ? 'alert-success' : 'alert-danger';
            const icon = type === 'success' ? 'fa-check-circle' : 'fa-exclamation-circle';

            const notification = document.createElement('div');
            notification.className = `alert ${alertClass} alert-dismissible fade show`;
            notification.setAttribute('role', 'alert');
            notification.innerHTML = `
                <i class="fas ${icon} me-2"></i>
                ${message}
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            `;

            // Add to current section
            const currentSection = document.querySelector('.section.active');
            if (currentSection) {
                currentSection.prepend(notification);
            }

            // Auto-remove success notifications
            if (type === 'success') {
                setTimeout(() => {
                    if (notification.parentNode) {
                        notification.remove();
                    }
                }, 5000);
            }
        }

        // Helper function to switch sections programmatically
        function switchToSection(sectionId) {
            const sectionItem = document.querySelector(`.sidebar-menu li[data-section="${sectionId}"]`);
            if (sectionItem) {
                sectionItem.click();
            }
        }

